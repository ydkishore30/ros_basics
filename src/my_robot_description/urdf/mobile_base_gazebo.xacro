<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ================= GAZEBO MATERIALS & PHYSICS ================= -->
  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
  </gazebo>

<gazebo reference="left_wheel_link">
  <mu1>50.0</mu1>
  <mu2>50.0</mu2>
  <kp>1000000.0</kp>
  <kd>100.0</kd>
</gazebo>

<gazebo reference="right_wheel_link">
  <mu1>50.0</mu1>
  <mu2>50.0</mu2>
  <kp>1000000.0</kp>
  <kd>100.0</kd>
</gazebo>

<gazebo reference="castor_wheel_link">
  <mu1>0.0</mu1>
  <mu2>0.0</mu2>
  <slip1>1.0</slip1>
  <slip2>1.0</slip2>
</gazebo>

  <!--
    The native Gazebo diff-drive plugin has been removed from here.
    The 'diff_drive_controller' in ros2_control handles the robot movements.
    The gz_ros2_control plugin itself is declared in mobile_base.ros2_control.xacro.
  -->

</robot>
