{
    "configurations": [
        {
            "name": "Linux",
            "includePath": [
                "${workspaceFolder}/src/**",
                "${workspaceFolder}/install/include",
                "/opt/ros/jazzy/include/**",
                "/usr/include",
                "/usr/local/include"
            ],
            "defines": [
                "__linux__",
                "ROS_DISTRO_JAZZY"
            ],
            "compilerPath": "/usr/bin/g++",
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "linux-gcc-x64",
            "browse": {
                "path": [
                    "${workspaceFolder}/src",
                    "${workspaceFolder}/install/include",
                    "/opt/ros/jazzy/include/**"
                ],
                "databaseFilename": "${workspaceFolder}/.vscode/browse.vc.db",
                "limitSymbolsToIncludedHeaders": true
            }
        }
    ],
    "version": 4
}